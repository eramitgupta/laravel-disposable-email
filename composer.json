{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "erag/laravel-disposable-email",
    "description": "A Laravel package to detect and block disposable email addresses.",
    "license": "MIT",
    "keywords": [
        "laravel",
        "disposable",
        "email",
        "validation",
        "email validator",
        "block disposable",
        "disposable check",
        "laravel email rule",
        "email blacklist",
        "temporary email",
        "fake email",
        "email validation rule",
        "laravel custom rule",
        "email filtering",
        "email domain checker"
    ],
    "authors": [
        {
            "name": "Er Amiit Gupta",
            "email": "info.eramitgupta@gmail.com",
            "homepage": "https://github.com/eramitgupta"
        }
    ],
    "require": {
        "php": ">=8.1.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/validation": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/translation": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^8.36|^9.15|^10.8|^11.0",
        "pestphp/pest": "^1.22|^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^1.3|^2.0|^3.0|^4.0"
  },
    "autoload": {
        "psr-4": {
            "EragLaravelDisposableEmail\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "pint --parallel",
        "test:lint": "pint --parallel --test",
        "test:unit": "pest --order-by=random",
        "test": ["@test:lint", "@test:unit"]
    },
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "EragLaravelDisposableEmail\\LaravelDisposableEmailServiceProvider"
            ],
            "aliases": {
                "Disposable": "EragLaravelDisposableEmail\\Facades\\Disposable"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
